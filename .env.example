# VELMA Knowledge Base Configuration
# Copia este archivo a .env y completa tus valores

# Nombre de tu proyecto (se usa como tag por defecto en docs_index)
PROJECT_NAME=my_project

# Nombre del desarrollador (para atribuir entradas)
DEV_NAME=developer

# Base de datos
DB_PATH=knowledge.db

# Modelo de embeddings (local, sin costo de API)
MODEL_NAME=all-MiniLM-L6-v2

# Threshold de confianza para búsqueda vectorial
# 0.50 recomendado para KB pequeñas (<200 entradas)
# 0.75 recomendado para KB maduras (>500 entradas)
MIN_CONFIDENCE_SCORE=0.50

# Días antes de que una entrada expire (requiere revisión)
DEFAULT_EXPIRY_DAYS=90

# Flask (panel web)
SECRET_KEY=velma-kb-change-this-in-production

# Sync con base de datos compartida (opcional, Fase 4)
SHARED_DB_PATH=shared_knowledge.db

# GitHub Actions (opcional, para merge automático en PRs)
GITHUB_TOKEN=
REPO_OWNER=
REPO_NAME=
