# VELMA Knowledge Base Configuration

# Base de datos
DB_PATH=knowledge.db

# Configuracion Ollama
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODEL=llama3.2:1b
OLLAMA_STARTUP_TIMEOUT=15

# Configuracion de expiracion
DEFAULT_EXPIRY_DAYS=90
MIN_CONFIDENCE_SCORE=0.50
VECTOR_SIMILARITY_THRESHOLD=0.85

# GitHub (para GitHub Actions)
GITHUB_TOKEN=
REPO_OWNER=
REPO_NAME=

# Configuracion del dev
DEV_NAME=developer
PROJECT_NAME=VELMA
