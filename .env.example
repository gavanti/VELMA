# VELMA Knowledge Base Configuration

# Base de datos
DB_PATH=knowledge.db

# Modelo de embeddings (local, sin costo de API)
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
MODEL_PATH=./models

# Modelo de Ollama para enriquecimiento (opcional)
OLLAMA_MODEL=llama3.2:1b

# Configuraci n de expiraci n
DEFAULT_EXPIRY_DAYS=90
MIN_CONFIDENCE_SCORE=0.50
VECTOR_SIMILARITY_THRESHOLD=0.85

# GitHub (para GitHub Actions)
GITHUB_TOKEN=
REPO_OWNER=
REPO_NAME=

# Configuraci n del dev
DEV_NAME=developer
PROJECT_NAME=my_project
